# Copy this file to .env and fill in your Discord bot settings.
# Never commit your real bot token.

DISCORD_TOKEN=your_discord_bot_token_here

# Optional. Used as the default notification channel until you set one in Discord
# with /notification_channel_setting.
RESULT_CHANNEL_ID=

# Optional. Used only for migrating old local data that had no server prefix.
GUILD_ID=

# Optional. Defaults to schedule.db.
DATABASE_PATH=schedule.db
